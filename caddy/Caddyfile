# --- SHORT NAME REDIRECTS (HTTP ONLY) ---
http://h, http://h.lan, http://h.tail357ab.ts.net, http://home.f, http://up.f, http://ha.f, http://outpost, http://up.o, http://c.f, http://c.o {
	@h host h h.lan h.tail357ab.ts.net home.f
	redir @h https://home.f.cordeiro.pt{uri}

	@up-f host up.f
	redir @up-f https://up.f.cordeiro.pt{uri}

	@ha host ha.f
	redir @ha https://ha.cordeiro.pt{uri}

	@outpost host outpost
	redir @outpost https://outpost.cordeiro.pt{uri}

	@up-o host up.o
	redir @up-o https://up.o.cordeiro.pt{uri}

	@c-f host c.f
	redir @c-f https://claude.f.cordeiro.pt{uri}

	@c-o host c.o
	redir @c-o https://claude.o.cordeiro.pt{uri}
}

